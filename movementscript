-- =========================================
-- UTILS
-- =========================================
local function updateVisualToggles()
    for name, button in pairs(CheckboxObjects) do
        button.BackgroundColor3 = states[name] and CONFIG.AccentColor or Color3.fromRGB(35, 35, 35)
    end
end

local function getMapCenter()
    local model = game.Workspace:FindFirstChild("Map") or game.Workspace:FindFirstChild("Stage") or game.Workspace
    if model:IsA("Model") then return model:GetModelCFrame().Position end
    return Vector3.new(0, 50, 0)
end

local function getAnimFromCatalog(catalogID)
    local success, obj = pcall(function() return game:GetObjects("rbxassetid://" .. catalogID)[1] end)
    if success and obj then
        if obj:IsA("Animation") then return obj.AnimationId end
        local inner = obj:FindFirstChildWhichIsA("Animation", true)
        if inner then return inner.AnimationId end
    end
    return "rbxassetid://" .. catalogID 
end

local function isTeammate(plr)
    if not plr or plr == lp then return true end
    local myTeamAttr = lp:GetAttribute("Team") or lp:GetAttribute("TeamID")
    local plrTeamAttr = plr:GetAttribute("Team") or plr:GetAttribute("TeamID")
    if myTeamAttr and plrTeamAttr and myTeamAttr == plrTeamAttr then return true end
    if plr.Team and lp.Team and plr.Team == lp.Team then return true end
    return false
end

local function getValidTarget()
    local nearest, dist = nil, math.huge
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    for _, v in pairs(game:GetService("Players"):GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local targetHum = v.Character:FindFirstChildOfClass("Humanoid")
            if targetHum and targetHum.Health > 0 then
                if not isTeammate(v) then
                    local d = (myRoot.Position - v.Character.HumanoidRootPart.Position).Magnitude
                    if d < dist then dist = d; nearest = v end
                end
            end
        end
    end
    return nearest
end

local function stopEverything()
    danceActive = false
    if danceTrack then pcall(function() danceTrack:Stop(); danceTrack:Destroy() end); danceTrack = nil end
    for k, _ in pairs(states) do states[k] = false end
    updateVisualToggles()
    local char = lp.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then 
            hum:SetStateEnabled(Enum.HumanoidStateType.Running, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
        end
        if char:FindFirstChild("Animate") then char.Animate.Disabled = false end
    end
end

-- =========================================
-- THE CORE ENGINE (GOD SPEED OPTIMIZED)
-- =========================================
RunService.RenderStepped:Connect(function(dt)
    local char = lp.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end

    if states["orbit"] or states["void spam"] or states["wallbang (tp)"] then
        hum:SetStateEnabled(Enum.HumanoidStateType.Running, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        
        -- High Velocity Overwrite
        root.AssemblyLinearVelocity = Vector3.new(0, 9e9, 0)
        root.AssemblyAngularVelocity = Vector3.new(0, 9e9, 0)

        if states["orbit"] and states["void spam"] then
            local t = tick() * 80
            local s = CONFIG.MapSpread
            local circleX = math.cos(t) * s
            local circleZ = math.sin(t) * s
            local rx, rz = math.random(-s, s), math.random(-s, s)
            root.CFrame = CFrame.new(circleX + rx, CONFIG.VoidDepth, circleZ + rz) * CFrame.Angles(math.rad(math.random(0,360)), math.rad(math.random(0,360)), math.rad(math.random(0,360)))
        
        elseif states["orbit"] then
            local center = getMapCenter()
            local s = CONFIG.MapSpread
            local t = tick() * 80
            local circleX = math.cos(t) * s
            local circleZ = math.sin(t) * s
            local rx, ry, rz = math.random(-s, s), math.random(-s, s), math.random(-s, s)
            root.CFrame = CFrame.new(center + Vector3.new(circleX + rx, ry, circleZ + rz)) * CFrame.Angles(math.rad(math.random(0,360)), math.rad(math.random(0,360)), math.rad(math.random(0,360)))
        
        elseif states["wallbang (tp)"] then
            local target = getValidTarget()
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                local tRoot = target.Character.HumanoidRootPart
                angle = (angle + (CONFIG.OrbitSpeed * dt)) % (math.pi * 2)
                local offset = Vector3.new(math.cos(angle) * CONFIG.OrbitRadius, CONFIG.OrbitYOffset, math.sin(angle) * CONFIG.OrbitRadius)
                root.CFrame = CFrame.lookAt(tRoot.Position + offset, tRoot.Position)
            end

        elseif states["void spam"] then
            root.CFrame = CFrame.new(root.Position.X, CONFIG.VoidDepth, root.Position.Z)
        end
    else
        if not hum:GetStateEnabled(Enum.HumanoidStateType.Running) then
            hum:SetStateEnabled(Enum.HumanoidStateType.Running, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
        end
    end

    if danceActive and currentAnimID then
        local animator = hum:FindFirstChildOfClass("Animator")
        if animator then
            if char:FindFirstChild("Animate") then char.Animate.Disabled = true end
            if not danceTrack or danceTrack.Animation.AnimationId ~= currentAnimID or not danceTrack.IsPlaying then
                if danceTrack then pcall(function() danceTrack:Stop() end) end
                local anim = Instance.new("Animation"); anim.AnimationId = currentAnimID
                local s, nt = pcall(function() return animator:LoadAnimation(anim) end)
                if s then danceTrack = nt; danceTrack.Priority = Enum.AnimationPriority.Action4; danceTrack.Looped = true; danceTrack:Play() end
            end
        end
    end
end)

