    local Sf = Instance.new("Frame", Sbg); Sf.Size = UDim2.new((def-min)/(max-min), 0, 1, 0); Sf.BackgroundColor3 = CONFIG.AccentColor; Sf.BorderSizePixel = 0
    local R = Instance.new("TextButton", p); R.Position = UDim2.new(0, x + 190, 0, y+10); R.Size = UDim2.new(0, 35, 0, 12); R.BackgroundColor3 = Color3.fromRGB(30, 30, 30); R.Text = "reset"; R.Font = Enum.Font.Code; R.TextSize = 9; R.TextColor3 = Color3.new(1,1,1)
    local function set(v) v = math.floor(v * 10) / 10; Sf.Size = UDim2.new((v-min)/(max-min), 0, 1, 0); L.Text = t..": "..v; func(v) end
    Sbg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then local conn; local function update() local pcent = math.clamp((UIS:GetMouseLocation().X - Sbg.AbsolutePosition.X) / Sbg.AbsoluteSize.X, 0, 1); set(min + (max-min) * pcent) end; update(); conn = RunService.RenderStepped:Connect(function() if not UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then conn:Disconnect() else update() end end) end end)
    R.MouseButton1Click:Connect(function() set(def) end)
end

